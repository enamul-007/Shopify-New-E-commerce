[
  {
    "name": "theme_info",
    "theme_name": "Starter theme",
    "theme_version": "1.0.0",
    "theme_author": "THEME_AUTHOR",
    "theme_documentation_url": "https://THEME_DOCUMENTATION_URL.com/",
    "theme_support_url": "https://THEME_SUPPORT_URL.com/"
  },

  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#c4cdd5",
        "info": "Buttons and special ornaments"
      },
      {
        "type": "radio",
        "id": "cart_display",
        "label": "Cart Display",
        "options": [
          {
            "value": "drawer",
            "label": "Cart Drawer"
          },
          {
            "value": "page",
            "label": "Cart Page"
          }
        ],
        "default": "drawer"
      },
      {
        "type": "color",
        "id": "color_body_text",
        "label": "Text",
        "default": "#161d25"
      },
      {
        "type": "color",
        "id": "color_main_bg",
        "label": "Background",
        "default": "#ffffff"
      }
    ]
  },

  {
    "name": "Typography",
    "settings": [

      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "helvetica_n4"
      },

      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "helvetica_n4"
      },

      {
        "type": "range",
        "id": "body_font_size",
        "label": "Body Font Size",
        "min": 12,
        "max": 22,
        "step": 1,
        "default": 16,
        "unit": "px"
      },

      {
        "type": "range",
        "id": "heading_font_size",
        "label": "Heading Font Size",
        "min": 18,
        "max": 60,
        "step": 1,
        "default": 32,
        "unit": "px"
      }

    ]
  },

  {
    "name": "Social media",
    "settings": [

      {
        "type": "header",
        "content": "Social sharing image"
      },

      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Image"
      },

      {
        "type": "header",
        "content": "Social sharing options"
      },

      {
        "type": "checkbox",
        "id": "social_sharing_blog",
        "label": "Enable sharing for blog articles",
        "default": true
      },

      {
        "type": "checkbox",
        "id": "share_facebook",
        "label": "Share on Facebook",
        "default": true
      },

      {
        "type": "checkbox",
        "id": "share_twitter",
        "label": "Tweet on Twitter",
        "default": true
      },

      {
        "type": "checkbox",
        "id": "share_pinterest",
        "label": "Pin on Pinterest",
        "default": true
      },

      {
        "type": "header",
        "content": "Sharing links"
      },

      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "Twitter link"
      },

      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "Facebook link"
      },

      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "Pinterest link"
      },

      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "Instagram link"
      },

      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "Youtube link"
      }

    ]
  },

  {
    "name": "Cart",
    "settings": [
      {
        "type": "checkbox",
        "id": "cart_notes_enable",
        "label": "Enable cart notes",
        "default": true
      }
    ]
  },

  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon image",
        "info": "Will be scaled down to 32x32px"
      }
    ]
  }
]