{% layout 'theme' %}

{{ 'wishlist.css' | asset_url | stylesheet_tag }}

<main class="wl-main">

  <div class="wl-layout">

    <!-- Sidebar -->
    <aside class="wl-sidebar">

      <!-- Profile -->
      <div class="wl-profile-card">

        <div class="wl-avatar-wrap">

          {% if customer.metafields.custom.avatar %}
            <img src="{{ customer.metafields.custom.avatar }}" class="wl-avatar-img">
          {% else %}
            <div class="wl-avatar-placeholder">
              <span class="material-symbols-outlined">person</span>
            </div>
          {% endif %}

        </div>

        <h2 class="wl-profile-name">
          {{ customer.name }}
        </h2>

        <span class="wl-profile-badge">

          {% if customer.tags contains 'gold' %}
            Gold Member
          {% elsif customer.tags contains 'silver' %}
            Silver Member
          {% else %}
            Member
          {% endif %}

        </span>

      </div>


      <!-- Navigation -->

      <nav class="wl-sidenav">

        <a href="/account" class="wl-sidenav-link active">
          Dashboard
        </a>

        <a href="/account#orders" class="wl-sidenav-link">
          My Orders
        </a>

        <a href="/account/addresses" class="wl-sidenav-link">
          Address Book
        </a>

        <a href="/account#wishlist" class="wl-sidenav-link">
          Wishlist
        </a>

        <hr class="wl-sidenav-divider">

        <a href="{{ routes.account_logout_url }}" class="wl-sidenav-link danger">
          Logout
        </a>

      </nav>

    </aside>



    <!-- Right Content -->

    <div class="wl-content">


      <!-- Dashboard -->

      <h2 id="orders">
        My Orders
      </h2>


      {% paginate customer.orders by 20 %}

      {% if customer.orders.size > 0 %}

      <table class="responsive-table">

        <thead>

          <tr>

            <th>Order</th>

            <th>Date</th>

            <th>Status</th>

            <th>Total</th>

          </tr>

        </thead>


        <tbody>

        {% for order in customer.orders %}

        <tr>

          <td>

            {{ order.name | link_to: order.customer_url }}

          </td>

          <td>

            {{ order.created_at | date: "%d %b %Y" }}

          </td>

          <td>

            {{ order.financial_status_label }}

          </td>

          <td>

            {{ order.total_price | money }}

          </td>

        </tr>

        {% endfor %}

        </tbody>

      </table>


      {% else %}

      <p>No orders yet</p>

      {% endif %}


      {% endpaginate %}



      <!-- Address -->

      <h2>
        Default Address
      </h2>


      {{ customer.default_address | format_address }}


      <br>

      <a href="/account/addresses">

        View Addresses

      </a>


      
   


    </div>


  </div>

</main>