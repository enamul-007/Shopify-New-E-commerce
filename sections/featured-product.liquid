{{ 'featured-products.css' | asset_url | stylesheet_tag }}

<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200"
/>

<div
  class="featured-products-section"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.bg_color }};
    --fp-columns-desktop: {{ section.settings.columns_desktop }};
    --fp-columns-mobile: {{ section.settings.columns_mobile }};
  "
>
  <div class="fp-wrapper">

    {% comment %} ── Header ── {% endcomment %}
    <div class="fp-header" style="border-color: {{ section.settings.border_color }};">
      <div>
        {%- if section.settings.title != blank -%}
          <h2 class="fp-header__title" style="color: {{ section.settings.title_color }};">
            {{ section.settings.title }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="fp-header__subtitle" style="color: {{ section.settings.subtitle_color }};">
            {{ section.settings.subtitle }}
          </p>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank and section.settings.view_all_url != blank -%}
        
          href="{{ section.settings.view_all_url }}"
          class="fp-header__link"
          style="color: {{ section.settings.link_color }};"
        >
          {{ section.settings.view_all_label }}
          <span class="material-symbols-outlined fp-icon" aria-hidden="true">arrow_forward</span>
        </a>
      {%- endif -%}
    </div>

    {% comment %} ── Product Grid ── {% endcomment %}
    <div class="fp-grid">
      {% for block in section.blocks %}
        {% if block.type == 'product_card' %}
          {%- assign product = block.settings.product -%}

          <div class="fp-card" {{ block.shopify_attributes }}>

            {% comment %} ── Media ── {% endcomment %}
            <div
              class="fp-card__media"
              style="background-color: {{ section.settings.card_bg_color }};"
            >
              {%- if block.settings.badge_text != blank -%}
                <span
                  class="fp-card__badge"
                  style="background-color: {{ section.settings.badge_bg }}; color: {{ section.settings.badge_color }};"
                >
                  {{ block.settings.badge_text }}
                </span>
              {%- endif -%}

              {%- if product != blank -%}
                <img
                  src="{{ product.featured_image | img_url: 'master' }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="fp-card__img"
                  loading="lazy"
                >
              {%- elsif block.settings.custom_image != blank -%}
                <img
                  src="{{ block.settings.custom_image | img_url: 'master' }}"
                  alt="{{ block.settings.custom_image.alt | escape }}"
                  class="fp-card__img"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'fp-card__img' }}
              {%- endif -%}

              {%- if product != blank -%}
                <button
                  type="button"
                  class="fp-card__cart-btn"
                  onclick="
                    fetch('/cart/add.js', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ id: {{ product.variants.first.id }}, quantity: 1 })
                    }).then(() => { window.location.href = '/cart'; })
                  "
                >
                  <span class="material-symbols-outlined" aria-hidden="true">shopping_bag</span>
                  {{ section.settings.cart_btn_label | default: 'Add to Cart' }}
                </button>
              {%- else -%}
                <button type="button" class="fp-card__cart-btn">
                  <span class="material-symbols-outlined" aria-hidden="true">shopping_bag</span>
                  {{ section.settings.cart_btn_label | default: 'Add to Cart' }}
                </button>
              {%- endif -%}
            </div>

            {% comment %} ── Card Body ── {% endcomment %}
            <div class="fp-card__body">

              {% comment %} Title {% endcomment %}
              {%- if block.settings.show_title -%}
                <h3
                  class="fp-card__name"
                  style="color: {{ section.settings.title_color }}; font-size: {{ block.settings.title_size }};"
                >
                  {%- if product != blank -%}
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  {%- elsif block.settings.custom_title != blank -%}
                    <a href="{{ block.settings.custom_url | default: '#' }}">{{ block.settings.custom_title }}</a>
                  {%- else -%}
                    <a href="#">Product Name</a>
                  {%- endif -%}
                </h3>
              {%- endif -%}

              {% comment %} Description {% endcomment %}
              {%- if block.settings.show_description -%}
                {%- if product != blank and product.description != blank -%}
                  <p
                    class="fp-card__description"
                    style="
                      color: {{ section.settings.subtitle_color }};
                      font-size: {{ block.settings.description_size }};
                      display: -webkit-box;
                      -webkit-line-clamp: {{ block.settings.description_lines }};
                      -webkit-box-orient: vertical;
                      overflow: hidden;
                    "
                  >
                    {{ product.description | strip_html | truncatewords: 20 }}
                  </p>
                {%- endif -%}
              {%- endif -%}

              {% comment %} Price {% endcomment %}
              {%- if block.settings.show_price -%}
                <div class="fp-card__price">
                  {%- if product != blank -%}
                    <span class="fp-card__price-current" style="color: {{ section.settings.title_color }};">
                      {{ product.price | money }}
                    </span>
                    {%- if product.compare_at_price > product.price -%}
                      <span class="fp-card__price-compare">
                        {{ product.compare_at_price | money }}
                      </span>
                    {%- endif -%}
                  {%- else -%}
                    <span class="fp-card__price-current" style="color: {{ section.settings.title_color }};">
                      {{ block.settings.custom_price | default: '$0.00' }}
                    </span>
                    {%- if block.settings.compare_price != blank -%}
                      <span class="fp-card__price-compare">{{ block.settings.compare_price }}</span>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}

            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "featured-products-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Featured Products"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our handpicked selection of premium essentials."
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View All Label",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View All Link"
    },
    {
      "type": "text",
      "id": "cart_btn_label",
      "label": "Add to Cart Button Text",
      "default": "Add to Cart"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (Desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns (Mobile)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card Background",
      "default": "#f1f5f9"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title Color",
      "default": "#0f172a"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle / Description Color",
      "default": "#64748b"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link / Accent Color",
      "default": "#197fe6"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Header Border Color",
      "default": "#e2e8f0"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge Background",
      "default": "#dbeafe"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge Text Color",
      "default": "#197fe6"
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product Card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "header",
          "content": "Manual Override"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Product Name",
          "default": "Product Name"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Product URL"
        },
        {
          "type": "text",
          "id": "custom_price",
          "label": "Price",
          "default": "$99.00"
        },
        {
          "type": "text",
          "id": "compare_price",
          "label": "Compare Price (optional)"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text"
        },
        {
          "type": "header",
          "content": "Show / Hide Elements"
        },
        {
          "type": "checkbox",
          "id": "show_title",
          "label": "Show Product Title",
          "default": true
        },
        {
          "type": "select",
          "id": "title_size",
          "label": "Title Size",
          "options": [
            { "value": "0.875rem", "label": "Small" },
            { "value": "1rem", "label": "Medium" },
            { "value": "1.125rem", "label": "Large" }
          ],
          "default": "0.875rem",
          "visible_if": "{{ block.settings.show_title }}"
        },
        {
          "type": "checkbox",
          "id": "show_price",
          "label": "Show Price",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_description",
          "label": "Show Description",
          "default": false
        },
        {
          "type": "range",
          "id": "description_lines",
          "label": "Description Max Lines",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 2,
          "visible_if": "{{ block.settings.show_description }}"
        },
        {
          "type": "select",
          "id": "description_size",
          "label": "Description Size",
          "options": [
            { "value": "0.75rem", "label": "Small" },
            { "value": "0.875rem", "label": "Medium" },
            { "value": "1rem", "label": "Large" }
          ],
          "default": "0.875rem",
          "visible_if": "{{ block.settings.show_description }}"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "badge_text": "New Arrival",
            "custom_title": "Chronos Series 01",
            "custom_price": "$249.00",
            "show_title": true,
            "show_price": true,
            "show_description": false
          }
        },
        {
          "type": "product_card",
          "settings": {
            "badge_text": "Limited",
            "custom_title": "Studio ANC Headset",
            "custom_price": "$399.00",
            "show_title": true,
            "show_price": true,
            "show_description": false
          }
        },
        {
          "type": "product_card",
          "settings": {
            "custom_title": "Retro-M 35mm",
            "custom_price": "$1,150.00",
            "show_title": true,
            "show_price": true,
            "show_description": false
          }
        },
        {
          "type": "product_card",
          "settings": {
            "badge_text": "Sale",
            "custom_title": "UltraBook Pro 14",
            "custom_price": "$1,899.00",
            "compare_price": "$2,100.00",
            "show_title": true,
            "show_price": true,
            "show_description": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
