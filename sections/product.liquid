{% comment %}
Section: sections/product-detail.liquid
{% endcomment %}

<section class="pd-section">
  <div class="container pd-container">

    <!-- Breadcrumb -->
    <nav class="pd-breadcrumb" aria-label="Breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="material-symbols-outlined">chevron_right</span>
      <a href="{{ routes.collections_url }}">Shop</a>
      {% if product.collections.first %}
      <span class="material-symbols-outlined">chevron_right</span>
      <a href="{{ product.collections.first.url }}">{{ product.collections.first.title }}</a>
      {% endif %}
      <span class="material-symbols-outlined">chevron_right</span>
      <span class="pd-breadcrumb-current">{{ product.title }}</span>
    </nav>

    <!-- Main Grid -->
    <div class="pd-grid">

      <!-- LEFT: Images -->
      <div class="pd-images">
        <div class="pd-main-image-wrap">
          {% assign main_image = product.selected_or_first_available_variant.image | default: product.featured_image %}
          <img src="{{ main_image | img_url: '800x' }}" alt="{{ main_image.alt | default: product.title | escape }}"
            class="pd-main-image" id="pd-main-image" width="800" height="800" loading="eager">
          <button class="pd-wishlist-btn" aria-label="Add to Wishlist" id="pd-wishlist-btn">
            <span class="material-symbols-outlined">favorite</span>
          </button>
        </div>

        {% if product.images.size > 1 %}
        <div class="pd-thumbs">
          {% for image in product.images %}
          <button class="pd-thumb {% if forloop.first %}active{% endif %}" data-src="{{ image | img_url: '800x' }}"
            data-alt="{{ image.alt | escape }}">
            <img src="{{ image | img_url: '160x' }}" alt="{{ image.alt | escape }}" loading="lazy" width="160"
              height="160">
          </button>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      <!-- RIGHT: Info -->
      <div class="pd-info">

        {% if product.tags contains 'best-seller' or product.tags contains 'Best Seller' %}
        <span class="pd-tag">Best Seller</span>
        {% elsif product.tags contains 'new' or product.tags contains 'New' %}
        <span class="pd-tag new">New Arrival</span>
        {% endif %}

        <h1 class="pd-title">{{ product.title }}</h1>

        <div class="pd-price-row">
          <span class="pd-price" id="pd-price">
            {{ product.selected_or_first_available_variant.price | money }}
          </span>
          {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
          <s class="pd-compare-price" id="pd-compare-price">
            {{ product.selected_or_first_available_variant.compare_at_price | money }}
          </s>
          {% else %}
          <s class="pd-compare-price" id="pd-compare-price" style="display:none;"></s>
          {% endif %}
          {% if product.available %}
          <span class="pd-stock-badge"><span class="pd-stock-dot"></span>In Stock</span>
          {% else %}
          <span class="pd-stock-badge out">Out of Stock</span>
          {% endif %}
        </div>

        <div class="pd-rating-row">
          <div class="pd-stars">
            {% for i in (1..5) %}
            <span class="material-symbols-outlined pd-star">star</span>
            {% endfor %}
          </div>
          <a href="#pd-reviews" class="pd-rating-link">
            ({{ section.settings.review_count | default: '0' }} reviews)
          </a>
        </div>

        <p class="pd-description">
          {{ product.description | strip_html | truncatewords: 50 }}
        </p>

        <form action="{{ routes.cart_add_url }}" method="post" id="pd-form">
          <input type="hidden" name="id" id="pd-variant-id"
            value="{{ product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" id="pd-qty-input" value="1">

          {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
          <div class="pd-option-group">
            <span class="pd-option-label">
              {{ option.name }}:
              <span class="pd-option-selected" id="pd-opt-{{ forloop.index }}">
                {{ option.selected_value }}
              </span>
            </span>

            {% if option.name == 'Color' or option.name == 'Colour' %}
            <div class="pd-color-swatches">
              {% for value in option.values %}
              <button type="button" class="pd-color-swatch {% if option.selected_value == value %}active{% endif %}"
                data-option-index="{{ forloop.parentloop.index0 }}" data-value="{{ value | escape }}"
                title="{{ value }}" style="background: {{ value | downcase | replace: ' ', '' }};">
              </button>
              {% endfor %}
            </div>

            {% elsif option.name == 'Size' %}
            <div class="pd-size-btns">
              {% for value in option.values %}
              <button type="button" class="pd-size-btn {% if option.selected_value == value %}active{% endif %}"
                data-option-index="{{ forloop.parentloop.index0 }}" data-value="{{ value | escape }}">
                {{ value }}
              </button>
              {% endfor %}
            </div>
            <button type="button" class="pd-size-guide-link">Size Guide</button>

            {% else %}
            <div class="pd-size-btns">
              {% for value in option.values %}
              <button type="button" class="pd-size-btn {% if option.selected_value == value %}active{% endif %}"
                data-option-index="{{ forloop.parentloop.index0 }}" data-value="{{ value | escape }}">
                {{ value }}
              </button>
              {% endfor %}
            </div>
            {% endif %}
          </div>
          {% endfor %}
          {% endunless %}

          <div class="pd-actions-row">
            <div class="pd-qty-wrap">
              <button type="button" class="pd-qty-btn" id="pd-qty-minus">−</button>
              <span class="pd-qty-display" id="pd-qty-display">1</span>
              <button type="button" class="pd-qty-btn" id="pd-qty-plus">+</button>
            </div>

            <button type="submit" class="pd-add-btn" id="pd-add-btn" {% unless product.available %}disabled{% endunless %}>
              <span class="material-symbols-outlined">shopping_cart</span>
              {% if product.available %}Add to Cart{% else %}Sold Out{% endif %}
            </button>

            <button type="button" class="pd-buy-btn" id="pd-buy-btn" {% unless product.available %}disabled{% endunless %}>
              Buy Now
            </button>
          </div>
        </form>

        <div class="pd-accordions">
          <details class="pd-accordion" open>
            <summary class="pd-accordion-summary">
              Product Details
              <span class="material-symbols-outlined pd-accordion-icon">expand_more</span>
            </summary>
            <div class="pd-accordion-body">{{ product.description }}</div>
          </details>

          <details class="pd-accordion">
            <summary class="pd-accordion-summary">
              Shipping & Returns
              <span class="material-symbols-outlined pd-accordion-icon">expand_more</span>
            </summary>
            <div class="pd-accordion-body">
              {{ section.settings.shipping_text | default: 'Free shipping on orders over $100. Returns accepted within 30 days of delivery.' }}
            </div>
          </details>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Related Products -->
{% if section.settings.related_collection != blank %}
  {% assign related = collections[section.settings.related_collection] %}
  {% if related and related.products_count > 0 %}
  <section class="pd-related">
    <div class="container">
      <div class="pd-related-header">
        <h2 class="pd-related-title">You Might Also Like</h2>
        <a href="{{ related.url }}" class="pd-related-view-all">View All</a>
      </div>
      <div class="pd-related-grid">
        {% for rp in related.products limit: 4 %}
          {% unless rp.id == product.id %}
          <div class="pd-related-card">
            <div class="pd-related-image-wrap">
              <a href="{{ rp.url }}">
                {% if rp.featured_image %}
                <img src="{{ rp.featured_image | img_url: '400x' }}" alt="{{ rp.featured_image.alt | escape }}"
                  class="pd-related-image" loading="lazy" width="400" height="400">
                {% else %}
                <div class="pd-related-no-image">
                  <span class="material-symbols-outlined">image_not_supported</span>
                </div>
                {% endif %}
              </a>
              <button class="pd-related-cart-btn" data-variant-id="{{ rp.first_available_variant.id }}">
                <span class="material-symbols-outlined">add_shopping_cart</span>
              </button>
            </div>
            <div class="pd-related-info">
              <h3 class="pd-related-name">
                <a href="{{ rp.url }}">{{ rp.title }}</a>
              </h3>
              <div class="pd-related-pricing">
                <span class="pd-related-price">{{ rp.price | money }}</span>
                {% if rp.compare_at_price > rp.price %}
                <s class="pd-related-compare">{{ rp.compare_at_price | money }}</s>
                {% endif %}
              </div>
            </div>
          </div>
          {% endunless %}
        {% endfor %}
      </div>
    </div>
  </section>
  {% endif %}
{% endif %}

<script>
(function() {

  var variants = {{ product.variants | json }};
  var selectedOptions = [
    {% for option in product.options_with_values %}
      '{{ option.selected_value | escape }}'{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  var mainImg = document.getElementById('pd-main-image');

  // ✅ Fix 1: Shopify.formatMoney() replace — নিজস্ব formatMoney function
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  // Thumbnails
  document.querySelectorAll('.pd-thumb').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.pd-thumb').forEach(function(t) { t.classList.remove('active'); });
      this.classList.add('active');
      if (mainImg) {
        mainImg.src = this.dataset.src;
        mainImg.alt = this.dataset.alt || '';
      }
    });
  });

  // Quantity
  var qty = 1;
  var qtyDisplay = document.getElementById('pd-qty-display');
  var qtyInput   = document.getElementById('pd-qty-input');

  function setQty(n) {
    qty = Math.max(1, n);
    if (qtyDisplay) qtyDisplay.textContent = qty;
    if (qtyInput)   qtyInput.value = qty;
  }

  var minusBtn = document.getElementById('pd-qty-minus');
  var plusBtn  = document.getElementById('pd-qty-plus');
  if (minusBtn) minusBtn.addEventListener('click', function() { setQty(qty - 1); });
  if (plusBtn)  plusBtn.addEventListener('click',  function() { setQty(qty + 1); });

  // Variant selection
  document.querySelectorAll('[data-option-index]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var idx = parseInt(this.dataset.optionIndex);
      selectedOptions[idx] = this.dataset.value;

      document.querySelectorAll('[data-option-index="' + idx + '"]').forEach(function(b) {
        b.classList.remove('active');
      });
      this.classList.add('active');

      var label = document.getElementById('pd-opt-' + (idx + 1));
      if (label) label.textContent = this.dataset.value;

      updateVariant();
    });
  });

  function updateVariant() {
    var matched = null;
    for (var i = 0; i < variants.length; i++) {
      var v    = variants[i];
      var opts = [v.option1, v.option2, v.option3].filter(Boolean);
      var match = selectedOptions.every(function(s, j) { return opts[j] === s; });
      if (match) { matched = v; break; }
    }
    if (!matched) return;

    document.getElementById('pd-variant-id').value = matched.id;

    var priceEl   = document.getElementById('pd-price');
    var compareEl = document.getElementById('pd-compare-price');

    // ✅ Fix 1: formatMoney instead of Shopify.formatMoney
    if (priceEl)   priceEl.textContent = formatMoney(matched.price);
    if (compareEl) {
      if (matched.compare_at_price > matched.price) {
        compareEl.textContent  = formatMoney(matched.compare_at_price);
        compareEl.style.display = '';
      } else {
        compareEl.style.display = 'none';
      }
    }

    if (matched.featured_image && mainImg) {
      mainImg.src = matched.featured_image.src.replace(/\.[^.]+$/, '') + '_800x.jpg';
    }

    var addBtn = document.getElementById('pd-add-btn');
    var buyBtn = document.getElementById('pd-buy-btn');

    if (addBtn) {
      addBtn.disabled   = !matched.available;
      addBtn.innerHTML  = matched.available
        ? '<span class="material-symbols-outlined">shopping_cart</span> Add to Cart'
        : 'Sold Out';
    }
    if (buyBtn) buyBtn.disabled = !matched.available;
  }

  // ✅ Fix 2: async/await → Promise.then()
  // Add to Cart
  var form = document.getElementById('pd-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      var vid    = document.getElementById('pd-variant-id').value;
      var qty    = parseInt(document.getElementById('pd-qty-input').value) || 1;
      if (!vid) return;

      var addBtn = document.getElementById('pd-add-btn');
      addBtn.disabled  = true;
      addBtn.innerHTML = '<span class="material-symbols-outlined">hourglass_top</span> Adding...';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: vid, quantity: qty })
      })
      .then(function(r) { return r.json(); })
      .then(function() {
        if (window.CartDrawer) {
          window.CartDrawer.refresh();
          window.CartDrawer.open();
        }
        addBtn.innerHTML = '<span class="material-symbols-outlined">check</span> Added!';
        setTimeout(function() {
          addBtn.disabled  = false;
          addBtn.innerHTML = '<span class="material-symbols-outlined">shopping_cart</span> Add to Cart';
        }, 1800);
      })
      .catch(function() {
        addBtn.disabled  = false;
        addBtn.innerHTML = '<span class="material-symbols-outlined">shopping_cart</span> Add to Cart';
      });
    });
  }

  // Buy Now
  var buyBtn = document.getElementById('pd-buy-btn');
  if (buyBtn) {
    buyBtn.addEventListener('click', function() {
      var vid = document.getElementById('pd-variant-id').value;
      var qty = document.getElementById('pd-qty-input').value || 1;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: vid, quantity: qty })
      })
      .then(function() {
        window.location.href = '/checkout';
      })
      .catch(function(err) {
        console.error('Buy now failed', err);
      });
    });
  }

  // Related products quick add
  document.querySelectorAll('.pd-related-cart-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var self = this;
      var vid  = this.dataset.variantId;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: vid, quantity: 1 })
      })
      .then(function() {
        if (window.CartDrawer) {
          window.CartDrawer.refresh();
          window.CartDrawer.open();
        }
        self.innerHTML = '<span class="material-symbols-outlined">check</span>';
        setTimeout(function() {
          self.innerHTML = '<span class="material-symbols-outlined">add_shopping_cart</span>';
        }, 1500);
      })
      .catch(function() {});
    });
  });

  // ✅ Fix 3: Wishlist — window.Wishlist API এর সাথে compatible
  var wishlistBtn = document.getElementById('pd-wishlist-btn');
  var productData = {
    id:        {{ product.selected_or_first_available_variant.id }},
    title:     {{ product.title | json }},
    price:     {{ product.selected_or_first_available_variant.price }},
    image:     {{ product.featured_image | img_url: '400x' | json }},
    url:       {{ product.url | json }},
    available: {{ product.available | json }}
  };

  function updateWishlistIcon() {
    if (!wishlistBtn) return;
    var icon = wishlistBtn.querySelector('.material-symbols-outlined');
    var inList = window.Wishlist ? window.Wishlist.has(productData.id) : false;
    if (inList) {
      wishlistBtn.classList.add('active');
      if (icon) icon.style.fontVariationSettings = "'FILL' 1, 'wght' 400";
    } else {
      wishlistBtn.classList.remove('active');
      if (icon) icon.style.fontVariationSettings = "'FILL' 0, 'wght' 400";
    }
  }

  if (wishlistBtn) {
    wishlistBtn.addEventListener('click', function() {
      if (window.Wishlist) {
        window.Wishlist.toggle(productData);
      }
      updateWishlistIcon();
    });
  }

  updateWishlistIcon();

  // Initialize first variant
  updateVariant();

})();
</script>

{% schema %}
{
  "name": "Product Detail",
  "settings": [
    {
      "type": "collection",
      "id": "related_collection",
      "label": "Related Products Collection"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count (display only)",
      "default": "128"
    },
    {
      "type": "textarea",
      "id": "shipping_text",
      "label": "Shipping & Returns Text",
      "default": "Free shipping on orders over $100. Returns accepted within 30 days of delivery."
    }
  ],
  "presets": [
    {
      "name": "Product Detail"
    }
  ]
}
{% endschema %}
