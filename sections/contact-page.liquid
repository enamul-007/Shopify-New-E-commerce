{% comment %}
  Section: sections/contact.liquid
{% endcomment %}

<div class="container mx-auto px-4 py-8 max-w-7xl">

  <!-- Breadcrumb -->
  <nav aria-label="Breadcrumb" class="contact-breadcrumb">
    <ol>
      <li><a href="{{ routes.root_url }}">Home</a></li>
      <li>
        <span class="material-symbols-outlined">chevron_right</span>
        <span aria-current="page">Contact Us</span>
      </li>
    </ol>
  </nav>

  <!-- Hero -->
  <div class="contact-hero">
    <h1 class="contact-hero-title">{{ section.settings.title | default: 'Contact Us' }}</h1>
    <p class="contact-hero-sub">{{ section.settings.subtitle | default: "We'd love to hear from you. Our team is always here to help." }}</p>
  </div>

  <!-- Main Grid -->
  <div class="contact-grid">

    <!-- LEFT: Form -->
    <div class="contact-form-card">
      <h2 class="contact-form-title">Send Us a Message</h2>

      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="contact-success">
            <span class="material-symbols-outlined">check_circle</span>
            Thank you! We'll get back to you within 24 hours.
          </div>
        {% endif %}

        {% if form.errors %}
          <div class="contact-error">
            <span class="material-symbols-outlined">error</span>
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="contact-form-row">
          <div class="contact-field">
            <label for="ContactFormName">Full Name</label>
            <input
              type="text"
              id="ContactFormName"
              name="contact[name]"
              value="{{ form.name }}"
              placeholder="John Doe"
              autocomplete="name"
            >
          </div>
          <div class="contact-field">
            <label for="ContactFormEmail">Email Address</label>
            <input
              type="email"
              id="ContactFormEmail"
              name="contact[email]"
              value="{{ form.email }}"
              placeholder="john@example.com"
              autocomplete="email"
              required
            >
          </div>
        </div>

        <div class="contact-field">
          <label for="ContactFormPhone">Phone (optional)</label>
          <input
            type="tel"
            id="ContactFormPhone"
            name="contact[phone]"
            value="{{ form.phone }}"
            placeholder="+1 (555) 000-0000"
            autocomplete="tel"
          >
        </div>

        <div class="contact-field">
          <label for="ContactFormMessage">Message</label>
          <textarea
            id="ContactFormMessage"
            name="contact[body]"
            placeholder="Write your message here..."
            rows="6"
            required
          >{{ form.body }}</textarea>
        </div>

        <button type="submit" class="contact-submit-btn">
          Send Message
          <span class="material-symbols-outlined">send</span>
        </button>

      {% endform %}
    </div>

    <!-- RIGHT: Info -->
    <div class="contact-info-col">

      <!-- Info Cards -->
      <div class="contact-info-cards">
        <div class="contact-info-card">
          <div class="contact-info-icon">
            <span class="material-symbols-outlined">location_on</span>
          </div>
          <h3>{{ section.settings.office_label | default: 'Our Office' }}</h3>
          <p>{{ section.settings.address | default: '123 Fashion Ave, New York, NY 10001' }}</p>
        </div>
        <div class="contact-info-card">
          <div class="contact-info-icon">
            <span class="material-symbols-outlined">call</span>
          </div>
          <h3>{{ section.settings.phone_label | default: 'Call Us' }}</h3>
          <p>{{ section.settings.phone | default: '+1 (555) 123-4567' }}<br>Mon–Fri, 9am–6pm</p>
        </div>
        <div class="contact-info-card">
          <div class="contact-info-icon">
            <span class="material-symbols-outlined">mail</span>
          </div>
          <h3>{{ section.settings.email_label | default: 'Email Us' }}</h3>
          <p>{{ section.settings.email | default: 'support@myshop.com' }}<br>Response in 24h</p>
        </div>
      </div>

      <!-- Map — Dynamic Google Maps Embed (API key লাগে না) -->
      <div class="contact-map">
        {% assign map_query = section.settings.map_address | default: '123 Fashion Ave, New York, NY 10001' | url_encode %}
        {% if section.settings.map_address != blank %}
          <iframe
            class="contact-map-iframe"
            src="https://maps.google.com/maps?q={{ map_query }}&output=embed&z=15"
            width="100%"
            height="100%"
            style="border:0; min-height: 18rem; display:block;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Store Location"
          ></iframe>
        {% else %}
          <!-- Fallback: address না দিলে placeholder দেখাবে -->
          <div class="contact-map-inner">
            <div class="contact-map-grid"></div>
            <div class="contact-map-blob contact-map-blob-1"></div>
            <div class="contact-map-blob contact-map-blob-2"></div>
            <div class="contact-map-pin">
              <span class="material-symbols-outlined">location_on</span>
              <div class="contact-map-pin-shadow"></div>
            </div>
            <div class="contact-map-label">Add address in Customizer</div>
          </div>
        {% endif %}
      </div>

      <!-- Social -->
      <div class="contact-social-bar">
        <span class="contact-social-label">Connect with us</span>
        <div class="contact-social-links">
          {% if section.settings.instagram_url != blank %}
            <a href="{{ section.settings.instagram_url }}" class="contact-social-btn" aria-label="Instagram" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          {% else %}
            <a href="#" class="contact-social-btn" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          {% endif %}

          {% if section.settings.twitter_url != blank %}
            <a href="{{ section.settings.twitter_url }}" class="contact-social-btn" aria-label="Twitter" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
            </a>
          {% else %}
            <a href="#" class="contact-social-btn" aria-label="Twitter">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
            </a>
          {% endif %}

          {% if section.settings.facebook_url != blank %}
            <a href="{{ section.settings.facebook_url }}" class="contact-social-btn" aria-label="Facebook" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
            </a>
          {% else %}
            <a href="#" class="contact-social-btn" aria-label="Facebook">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

    </div>
  </div>

  <!-- FAQ CTA -->
  <div class="contact-faq-cta">
    <p>
      Looking for quick answers?
      <a href="{{ pages['faq'].url | default: '#' }}" class="contact-faq-link">
        Visit our FAQ
        <span class="material-symbols-outlined">arrow_forward</span>
      </a>
    </p>
  </div>

</div>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    { "type": "text",    "id": "title",        "label": "Page Title",       "default": "Contact Us" },
    { "type": "text",    "id": "subtitle",     "label": "Subtitle",         "default": "We'd love to hear from you. Our team is always here to help." },
    { "type": "text",    "id": "office_label", "label": "Office Card Label","default": "Our Office" },
    { "type": "text",    "id": "address",      "label": "Address",          "default": "123 Fashion Ave, New York, NY 10001" },
    { "type": "text",    "id": "map_address",  "label": "Map Address", "default": "123 Fashion Ave, New York, NY 10001" },
    { "type": "text",    "id": "phone_label",  "label": "Phone Card Label", "default": "Call Us" },
    { "type": "text",    "id": "phone",        "label": "Phone Number",     "default": "+1 (555) 123-4567" },
    { "type": "text",    "id": "email_label",  "label": "Email Card Label", "default": "Email Us" },
    { "type": "text",    "id": "email",        "label": "Support Email",    "default": "support@myshop.com" },
    { "type": "url",     "id": "instagram_url","label": "Instagram URL" },
    { "type": "url",     "id": "twitter_url",  "label": "Twitter URL" },
    { "type": "url",     "id": "facebook_url", "label": "Facebook URL" }
  ],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
