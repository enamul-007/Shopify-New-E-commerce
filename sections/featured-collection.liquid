<section class="featured-collections-section">
  <div class="container">
    <div class="featured-collections-grid">
      {% for block in section.blocks %}
        <div class="featured-collection-card" {{ block.shopify_attributes }}>
          <div class="featured-collection-bg" style="background-image: url('{{ block.settings.image | img_url: 'master' }}')"></div>
          <div class="featured-collection-overlay"></div>
          <div class="featured-collection-content">
            <h3>{{ block.settings.title }}</h3>
            <p>{{ block.settings.subtitle }}</p>
            <a href="{{ block.settings.link }}" class="collection-link">
              View Collection <span class="material-symbols-outlined">arrow_forward</span>
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "class": "featured-collections-wrapper",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Women's Collection"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Discover the latest trends for her."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        { "type": "collection_card", "settings": { "title": "Women's Collection", "subtitle": "Discover the latest trends for her." } },
        { "type": "collection_card", "settings": { "title": "Men's Collection", "subtitle": "Upgrade your wardrobe with style." } }
      ]
    }
  ]
}
{% endschema %}
