<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

<section class="featured-collections-section">
  <div class="container">
    <div class="featured-collections-grid">

      {% for block in section.blocks %}
        <div
          class="featured-collection-card"
          {{ block.shopify_attributes }}
        >
          <div
            class="featured-collection-bg"
            style="background-image: url('{{ block.settings.image | img_url: 'master' }}');"
          ></div>

          <div class="featured-collection-overlay"></div>

          <div class="featured-collection-content">

            {%- if block.settings.show_title and block.settings.title != blank -%}
              <h3>{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.show_subtitle and block.settings.subtitle != blank -%}
              <p>{{ block.settings.subtitle }}</p>
            {%- endif -%}

            {%- if block.settings.show_button and block.settings.button_label != blank -%}
              <a href="{{ block.settings.link | default: '#' }}" class="collection-link">
                {{ block.settings.button_label }}
                <span class="material-symbols-outlined">arrow_forward</span>
              </a>
            {%- endif -%}

          </div>
        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collections",
  "tag": "section",
  "class": "featured-collections-wrapper",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "header",
          "content": "Title"
        },
        {
          "type": "checkbox",
          "id": "show_title",
          "label": "Show Title",
          "default": true
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Women's Collection"
        },
        {
          "type": "header",
          "content": "Subtitle"
        },
        {
          "type": "checkbox",
          "id": "show_subtitle",
          "label": "Show Subtitle",
          "default": true
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Discover the latest trends for her."
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "checkbox",
          "id": "show_button",
          "label": "Show Button",
          "default": true
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Text",
          "default": "View Collection"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Collections",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "title": "Women's Collection",
            "subtitle": "Discover the latest trends for her.",
            "button_label": "View Collection"
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Men's Collection",
            "subtitle": "Upgrade your wardrobe with style.",
            "button_label": "View Collection"
          }
        }
      ]
    }
  ]
}
{% endschema %}
