{%- style -%}
.hero-section-{{ section.id }} {
  background-image: url('{{ section.settings.background_image | image_url }}');
  display: flex;
  align-items: center;
  justify-content: {{ section.settings.content_alignment }};
  text-align: {%- if section.settings.content_alignment == 'flex-start' -%}left{%- elsif section.settings.content_alignment == 'flex-end' -%}right{%- else -%}center{%- endif -%};
  min-height: 600px;
  background-size: cover;
  background-position: center;
  position: relative;
}

.hero-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.5);
}

.hero-content {
  position: relative;
  z-index: 2;
  max-width: 600px;
  padding: 60px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

/* Elements */
.hero-badge {
  background: rgba(255,255,255,0.2);
  color: #fff;
  padding: 6px 14px;
  border-radius: 20px;
  width: fit-content;
}

.hero-title {
  color: #fff;
  font-size: 40px;
  font-weight: bold;
}

.hero-text {
  color: #ddd;
}

.hero-buttons {
  display: flex;
  gap: 10px;
}

.btn {
  padding: 12px 20px;
  text-decoration: none;
  font-weight: 600;
}

.btn-primary {
  background: #e8c87a;
  color: #000;
}

.btn-outline {
  border: 1px solid #fff;
  color: #fff;
}
{%- endstyle -%}

<section class="hero-section-{{ section.id }}">
  <div class="hero-overlay"></div>

  <div class="hero-content">

    {% for block in section.blocks %}
      
      {% case block.type %}

        {% when 'badge' %}
          <div class="hero-badge" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>

        {% when 'heading' %}
          <h1 class="hero-title" {{ block.shopify_attributes }}>
            {{ block.settings.heading }}
          </h1>

        {% when 'text' %}
          <p class="hero-text" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </p>

        {% when 'button' %}
          <div class="hero-buttons" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link }}" class="btn btn-primary">
              {{ block.settings.label }}
            </a>
          </div>

      {% endcase %}

    {% endfor %}

  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge Text",
          "default": "New"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Hero Title"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Add your description here"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button Label",
          "default": "Shop Now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "badge" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}