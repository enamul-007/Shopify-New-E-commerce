{%- style -%}
.hero-section-{{ section.id }} {
  background-image: url('{{ section.settings.background_image | img_url: 'master' }}');
  display: flex;
  align-items: center;
  justify-content: {{ section.settings.content_alignment }};
  text-align: {%- if section.settings.content_alignment == 'flex-start' -%}left{%- elsif section.settings.content_alignment == 'flex-end' -%}right{%- else -%}center{%- endif -%};
  min-height: 600px;
  background-size: cover;
  background-position: center;
  position: relative;
  box-sizing: border-box;
}

.hero-section-{{ section.id }} .hero-overlay {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: linear-gradient(to right, #121212 0%, rgba(18, 18, 18, 0.7) 60%, transparent 100%);
  z-index: 1;
}

.hero-section-{{ section.id }} .hero-content {
  position: relative;
  z-index: 2;
  max-width: 600px;
  padding: 60px 50px;
  box-sizing: border-box;
}

.hero-section-{{ section.id }} .hero-badge {
  display: inline-block;
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  padding: 6px 16px;
  border-radius: 50px;
  border: 1px solid rgba(255,255,255,0.3);
  margin-bottom: 18px;
}

.hero-section-{{ section.id }} .hero-title {
  color: #fff;
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  line-height: 1.2;
  margin: 0 0 16px;
}

.hero-section-{{ section.id }} .hero-title-accent {
  color: #e8c87a;
}

.hero-section-{{ section.id }} .hero-subtitle {
  color: rgba(255, 255, 255, 0.8);
  font-size: 1rem;
  line-height: 1.6;
  margin: 0;
}

.hero-section-{{ section.id }} .hero-buttons {
  display: flex;
  gap: 15px;
  flex-wrap: wrap;
  justify-content: {%- if section.settings.content_alignment == 'flex-start' -%}flex-start{%- elsif section.settings.content_alignment == 'flex-end' -%}flex-end{%- else -%}center{%- endif -%};
  margin-top: 25px;
}

.hero-section-{{ section.id }} .btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  border-radius: 4px;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  cursor: pointer;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.hero-section-{{ section.id }} .btn-primary {
  background-color: #e8c87a;
  color: #121212;
  border: 2px solid #e8c87a;
}

.hero-section-{{ section.id }} .btn-primary:hover {
  background-color: #d4b060;
  border-color: #d4b060;
  color: #121212;
}

.hero-section-{{ section.id }} .btn-outline {
  background-color: transparent;
  color: #fff;
  border: 2px solid rgba(255, 255, 255, 0.6);
}

.hero-section-{{ section.id }} .btn-outline:hover {
  background-color: rgba(255, 255, 255, 0.1);
  border-color: #fff;
}

.hero-section-{{ section.id }} .btn .btn-icon {
  font-size: 18px;
  line-height: 1;
}

@media screen and (max-width: 749px) {
  .hero-section-{{ section.id }} {
    justify-content: center;
    text-align: center;
    min-height: 500px;
  }

  .hero-section-{{ section.id }} .hero-content {
    padding: 40px 20px;
    max-width: 100%;
  }

  .hero-section-{{ section.id }} .hero-buttons {
    justify-content: center;
  }

  .hero-section-{{ section.id }} .hero-overlay {
    background: rgba(18, 18, 18, 0.6);
  }
}
{%- endstyle -%}

<!-- Material Symbols font (icon er jonno) -->
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />

<section class="hero-section hero-section-{{ section.id }}">
  <div class="hero-overlay"></div>
  <div class="hero-content">

    {%- if section.settings.badge_text != blank -%}
      <span class="hero-badge">{{ section.settings.badge_text }}</span>
    {%- endif -%}

    {%- if section.settings.heading_line1 != blank or section.settings.heading_line2 != blank -%}
      <h1 class="hero-title">
        {%- if section.settings.heading_line1 != blank -%}
          {{ section.settings.heading_line1 }}
        {%- endif -%}
        {%- if section.settings.heading_line2 != blank -%}
          <br><span class="hero-title-accent">{{ section.settings.heading_line2 }}</span>
        {%- endif -%}
      </h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}

    {%- if section.settings.show_primary_button or section.settings.show_secondary_button -%}
      <div class="hero-buttons">

        {%- if section.settings.show_primary_button and section.settings.primary_button_label != blank -%}
          <a href="{{ section.settings.primary_button_url | default: '#' }}" class="btn btn-primary">
            {{ section.settings.primary_button_label }}
            <span class="material-symbols-outlined btn-icon" aria-hidden="true">arrow_forward</span>
          </a>
        {%- endif -%}

        {%- if section.settings.show_secondary_button and section.settings.secondary_button_label != blank -%}
          <a href="{{ section.settings.secondary_button_url | default: '#' }}" class="btn btn-outline">
            {{ section.settings.secondary_button_label }}
          </a>
        {%- endif -%}

      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "New Season"
    },
    {
      "type": "text",
      "id": "heading_line1",
      "label": "Heading Line 1",
      "default": "Discover Your"
    },
    {
      "type": "text",
      "id": "heading_line2",
      "label": "Heading Line 2 (Accent)",
      "default": "Unique Style"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium fashion for the modern lifestyle."
    },
    {
      "type": "header",
      "content": "Primary Button"
    },
    {
      "type": "checkbox",
      "id": "show_primary_button",
      "label": "Show Primary Button",
      "default": true
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "primary_button_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Secondary Button"
    },
    {
      "type": "checkbox",
      "id": "show_secondary_button",
      "label": "Show Secondary Button",
      "default": true
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Button Label",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "secondary_button_url",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
