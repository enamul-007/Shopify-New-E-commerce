{% comment %}
  Section: sections/account.liquid
  — Hash-based tab navigation:
    /account           → Dashboard
    /account#orders    → My Orders  
    /account#wishlist  → Wishlist
    /account#addresses → Address Book
{% endcomment %}
{{ 'account.css' | asset_url | stylesheet_tag }}

<main class="ac-main">
  <div class="ac-layout">

    <!-- ===== SIDEBAR ===== -->
    <aside class="ac-sidebar">

      <!-- Profile -->
      <div class="ac-profile-card">
        <div class="ac-avatar-wrap">
          {% if customer.metafields.custom.avatar %}
            <img src="{{ customer.metafields.custom.avatar }}" alt="{{ customer.name }}" class="ac-avatar-img">
          {% else %}
            <div class="ac-avatar-placeholder">
              <span class="material-symbols-outlined">person</span>
            </div>
          {% endif %}
        </div>
        <h2 class="ac-profile-name">{{ customer.name | default: 'Guest' }}</h2>
        <span class="ac-profile-badge">
          {% if customer.tags contains 'gold' %}Gold Member
          {% elsif customer.tags contains 'silver' %}Silver Member
          {% else %}Member{% endif %}
        </span>
      </div>

      <!-- Nav -->
      <nav class="ac-sidenav">
        <a href="#dashboard"  class="ac-sidenav-link ac-tab-trigger" data-tab="dashboard">
          <span class="material-symbols-outlined">dashboard</span> Dashboard
        </a>
        <a href="#orders"     class="ac-sidenav-link ac-tab-trigger" data-tab="orders">
          <span class="material-symbols-outlined">package_2</span> My Orders
        </a>
        <a href="#addresses"  class="ac-sidenav-link ac-tab-trigger" data-tab="addresses">
          <span class="material-symbols-outlined">location_on</span> Address Book
        </a>
        <a href="#wishlist"   class="ac-sidenav-link ac-tab-trigger" data-tab="wishlist">
          <span class="material-symbols-outlined">favorite</span> Wishlist
        </a>
        <a href="#payment"    class="ac-sidenav-link ac-tab-trigger" data-tab="payment">
          <span class="material-symbols-outlined">credit_card</span> Payment Methods
        </a>
        <hr class="ac-sidenav-divider">
        <a href="{{ routes.account_logout_url }}" class="ac-sidenav-link danger">
          <span class="material-symbols-outlined">logout</span> Sign Out
        </a>
      </nav>

    </aside>

    <!-- ===== MAIN CONTENT ===== -->
    <div class="ac-content">

      <!-- ==================== TAB: DASHBOARD ==================== -->
      <div class="ac-tab-pane" id="tab-dashboard">

        <div class="ac-page-header">
          <h2 class="ac-page-title">Welcome back, {{ customer.first_name | default: 'there' }}!</h2>
          <p class="ac-page-sub">Here's what's happening with your account today.</p>
        </div>

        <!-- Stats -->
        <div class="ac-stats">
          <div class="ac-stat-card">
            <div class="ac-stat-top">
              <span class="ac-stat-label">Total Orders</span>
              <span class="material-symbols-outlined ac-stat-icon primary">shopping_bag</span>
            </div>
            <div class="ac-stat-value">{{ customer.orders_count }}</div>
          </div>
          <div class="ac-stat-card">
            <div class="ac-stat-top">
              <span class="ac-stat-label">Total Spent</span>
              <span class="material-symbols-outlined ac-stat-icon green">payments</span>
            </div>
            <div class="ac-stat-value">{{ customer.total_spent | money }}</div>
          </div>
          <div class="ac-stat-card">
            <div class="ac-stat-top">
              <span class="ac-stat-label">Loyalty Points</span>
              <span class="material-symbols-outlined ac-stat-icon amber">stars</span>
            </div>
            <div class="ac-stat-value">{{ customer.metafields.loyalty.points | default: '0' }}</div>
          </div>
        </div>

        <!-- Recent Orders -->
        <section class="ac-card">
          <div class="ac-card-header">
            <h3 class="ac-section-title">Recent Orders</h3>
            <a href="#orders" class="ac-view-all ac-tab-trigger" data-tab="orders">View All</a>
          </div>
          <div class="ac-table-wrap">
            <table class="ac-table">
              <thead><tr>
                <th>Order ID</th><th>Date</th><th>Status</th><th>Total</th><th>Action</th>
              </tr></thead>
              <tbody>
                {% for order in customer.orders limit: 5 %}
                  {% assign sl = order.fulfillment_status | downcase %}
                  {% if order.cancelled %}
                    {% assign bc = 'ac-badge cancelled' %}
                    {% assign ac_bt = 'Cancelled' %}
                  {% elsif sl == 'fulfilled' %}
                    {% assign bc = 'ac-badge shipped' %}
                    {% assign ac_bt = 'Shipped' %}
                  {% elsif sl == 'partial' %}
                    {% assign bc = 'ac-badge partial' %}
                    {% assign ac_bt = 'Partial' %}
                  {% else %}
                    {% assign bc = 'ac-badge processing' %}
                    {% assign ac_bt = 'Processing' %}
                  {% endif %}
                  <tr>
                    <td class="ac-order-id">{{ order.name }}</td>
                    <td class="ac-order-date">{{ order.created_at | date: '%b %d, %Y' }}</td>
                    <td><span class="{{ bc }}">{{ ac_bt }}</span></td>
                    <td class="ac-order-total">{{ order.total_price | money }}</td>
                    <td><a href="{{ order.customer_url }}" class="ac-link">View Details</a></td>
                  </tr>
                {% else %}
                  <tr><td colspan="5" class="ac-empty-row">No orders yet</td></tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </section>

        <!-- Address + Settings -->
        <div class="ac-two-col">
          <section class="ac-card">
            <div class="ac-card-header">
              <h3 class="ac-section-title">Shipping Address</h3>
              <a href="#addresses" class="ac-edit-btn ac-tab-trigger" data-tab="addresses">
                <span class="material-symbols-outlined">edit</span> Edit
              </a>
            </div>
            {% assign da = customer.default_address %}
            {% if da %}
              <div class="ac-address-row">
                <div class="ac-address-icon"><span class="material-symbols-outlined">home</span></div>
                <div>
                  <p class="ac-address-label">Primary Home</p>
                  <p class="ac-address-text">
                    {{ da.address1 }}{% if da.address2 %}, {{ da.address2 }}{% endif %}<br>
                    {{ da.city }}, {{ da.province_code }} {{ da.zip }}<br>
                    {{ da.country }}
                  </p>
                </div>
              </div>
            {% else %}
              <div class="ac-empty-state">
                <span class="material-symbols-outlined">add_location_alt</span>
                <p>No address saved yet.</p>
                <a href="#addresses" class="ac-link ac-tab-trigger" data-tab="addresses">Add Address</a>
              </div>
            {% endif %}
          </section>

          <section class="ac-card">
            <h3 class="ac-section-title" style="margin-bottom:1.5rem;">Quick Settings</h3>
            <div class="ac-settings-list">
              <div class="ac-setting-row">
                <div class="ac-setting-label">
                  <span class="material-symbols-outlined">mail</span><span>Email Notifications</span>
                </div>
                <label class="ac-toggle">
                  <input type="checkbox" class="ac-toggle-input" checked>
                  <span class="ac-toggle-track"></span>
                </label>
              </div>
              <div class="ac-setting-row">
                <div class="ac-setting-label">
                  <span class="material-symbols-outlined">security</span><span>2FA Security</span>
                </div>
                <label class="ac-toggle">
                  <input type="checkbox" class="ac-toggle-input">
                  <span class="ac-toggle-track"></span>
                </label>
              </div>
            </div>
          </section>
        </div>

      </div><!-- /tab-dashboard -->


      <!-- ==================== TAB: ORDERS ==================== -->
      <div class="ac-tab-pane" id="tab-orders">

        <div class="ac-page-header">
          <nav class="ac-breadcrumb">
            <a href="#dashboard" class="ac-tab-trigger" data-tab="dashboard">Dashboard</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span>My Orders</span>
          </nav>
          <h2 class="ac-page-title">My Orders</h2>
        </div>

        <!-- Filter Tabs -->
        <div class="ac-order-tabs-wrap">
          <div class="ac-order-tabs">
            <button class="ac-order-tab active" data-filter="all">All Orders</button>
            <button class="ac-order-tab" data-filter="unfulfilled">In Progress</button>
            <button class="ac-order-tab" data-filter="fulfilled">Shipped</button>
            <button class="ac-order-tab" data-filter="cancelled">Cancelled</button>
          </div>
        </div>

        <div class="ac-orders-list">
          {% for order in customer.orders %}
            {% assign sl = order.fulfillment_status | downcase %}
            {% if order.cancelled %}
              {% assign bc = 'ac-badge cancelled' %}
              {% assign ac_bt = 'Cancelled' %}
              {% assign ac_filter = 'cancelled' %}
            {% elsif sl == 'fulfilled' %}
              {% assign bc = 'ac-badge shipped' %}
              {% assign ac_bt = 'Shipped' %}
              {% assign ac_filter = 'fulfilled' %}
            {% elsif sl == 'partial' %}
              {% assign bc = 'ac-badge partial' %}
              {% assign ac_bt = 'Partial' %}
              {% assign ac_filter = 'partial' %}
            {% else %}
              {% assign bc = 'ac-badge processing' %}
              {% assign ac_bt = 'In Progress' %}
              {% assign ac_filter = 'unfulfilled' %}
            {% endif %}

            <div class="ac-order-card" data-filter="{{ ac_filter }}">
              <div class="ac-order-header">
                <div class="ac-order-meta">
                  <div>
                    <p class="ac-meta-label">Order Number</p>
                    <p class="ac-meta-value">{{ order.name }}</p>
                  </div>
                  <div>
                    <p class="ac-meta-label">Date Placed</p>
                    <p class="ac-meta-date">{{ order.created_at | date: '%b %d, %Y' }}</p>
                  </div>
                </div>
                <span class="{{ bc }}">{{ ac_bt }}</span>
              </div>
              <div class="ac-order-products">
                {% for item in order.line_items limit: 3 %}
                  {% if item.image %}
                    <img src="{{ item.image | img_url: '120x' }}" alt="{{ item.title | escape }}"
                      class="ac-product-img {% if order.cancelled %}ac-grayscale{% endif %}" loading="lazy">
                  {% endif %}
                {% endfor %}
                {% if order.line_items.size > 3 %}
                  <div class="ac-more-items">+{{ order.line_items.size | minus: 3 }} more</div>
                {% endif %}
                {% if order.line_items.size == 1 %}
                  {% assign item = order.line_items.first %}
                  <div class="ac-single-item">
                    <span class="ac-single-title">{{ item.title }}</span>
                    {% if item.variant.title != 'Default Title' %}
                      <span class="ac-single-variant">{{ item.variant.title }}</span>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
              <div class="ac-order-footer">
                <div class="ac-order-total-wrap">
                  <span class="ac-total-label">Total:</span>
                  <span class="ac-total-value">{{ order.total_price | money }}</span>
                </div>
                <div class="ac-order-actions">
                  <a href="{{ order.customer_url }}" class="ac-btn secondary">View Details</a>
                  {% unless order.cancelled %}
                    {% if sl == 'fulfilled' and order.fulfillments.first.tracking_url != blank %}
                      <a href="{{ order.fulfillments.first.tracking_url }}" target="_blank" class="ac-btn secondary">Track Package</a>
                    {% elsif sl == 'unfulfilled' %}
                      <a href="{{ order.customer_url }}" class="ac-btn secondary">Modify Order</a>
                    {% endif %}
                  {% endunless %}
                  <form action="{{ routes.cart_add_url }}" method="post" style="display:inline-flex;">
                    {% for li in order.line_items %}
                      <input type="hidden" name="items[][id]"       value="{{ li.variant.id }}">
                      <input type="hidden" name="items[][quantity]" value="{{ li.quantity }}">
                    {% endfor %}
                    <button type="submit" class="ac-btn primary">Buy Again</button>
                  </form>
                </div>
              </div>
            </div>
          {% else %}
            <div class="ac-empty-state" style="padding:3rem;">
              <span class="material-symbols-outlined">package_2</span>
              <p>No orders yet</p>
              <a href="{{ routes.collections_url }}" class="ac-btn primary">Start Shopping</a>
            </div>
          {% endfor %}
        </div>

      </div><!-- /tab-orders -->


      <!-- ==================== TAB: ADDRESSES ==================== -->
      <div class="ac-tab-pane" id="tab-addresses">

        <div class="ac-page-header">
          <nav class="ac-breadcrumb">
            <a href="#dashboard" class="ac-tab-trigger" data-tab="dashboard">Dashboard</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span>Address Book</span>
          </nav>
          <h2 class="ac-page-title">Address Book</h2>
        </div>

        {% paginate customer.addresses by 10 %}
          <div class="ac-addresses-grid">
            {% for address in customer.addresses %}
              <div class="ac-address-card {% if address == customer.default_address %}ac-address-default{% endif %}">
                {% if address == customer.default_address %}
                  <span class="ac-default-badge">Default</span>
                {% endif %}
                <p class="ac-address-name">{{ address.name }}</p>
                <p class="ac-address-body">
                  {{ address.address1 }}{% if address.address2 %}<br>{{ address.address2 }}{% endif %}<br>
                  {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
                  {{ address.country }}
                </p>
                {% if address.phone != blank %}
                  <p class="ac-address-phone">{{ address.phone }}</p>
                {% endif %}
                <div class="ac-address-actions">
                  <a href="{{ routes.account_url }}/addresses/{{ address.id }}" class="ac-btn secondary">Edit</a>
                  {% unless address == customer.default_address %}
                    <form action="{{ routes.account_url }}/addresses/{{ address.id }}" method="post">
                      <input type="hidden" name="_method" value="delete">
                      {{ form.authenticity_token }}
                      <button type="submit" class="ac-btn danger-outline"
                        onclick="return confirm('Delete this address?')">Delete</button>
                    </form>
                  {% endunless %}
                </div>
              </div>
            {% endfor %}
            <a href="{{ routes.account_url }}/addresses/new" class="ac-address-card ac-add-address">
              <span class="material-symbols-outlined">add_location_alt</span>
              <span>Add New Address</span>
            </a>
          </div>
        {% endpaginate %}

      </div><!-- /tab-addresses -->


      <!-- ==================== TAB: WISHLIST ==================== -->
      <div class="ac-tab-pane" id="tab-wishlist">

        <div class="ac-page-header">
          <nav class="ac-breadcrumb">
            <a href="#dashboard" class="ac-tab-trigger" data-tab="dashboard">Dashboard</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span>Wishlist</span>
          </nav>
          <div class="ac-wishlist-header-row">
            <h2 class="ac-page-title">
              My Wishlist <span class="ac-item-count" id="wl-count">0 Items</span>
            </h2>
            <button class="ac-btn primary" id="wl-add-all" disabled>
              <span class="material-symbols-outlined">shopping_cart_checkout</span> Add All to Cart
            </button>
          </div>
        </div>

        <div class="ac-wl-grid" id="wl-grid">
          <div class="ac-empty-state" id="wl-empty">
            <span class="material-symbols-outlined">favorite_border</span>
            <p>Your wishlist is empty</p>
            <a href="{{ routes.collections_url }}" class="ac-btn primary">Start Shopping</a>
          </div>
        </div>

      </div><!-- /tab-wishlist -->


      <!-- ==================== TAB: PAYMENT ==================== -->
      <div class="ac-tab-pane" id="tab-payment">

        <div class="ac-page-header">
          <nav class="ac-breadcrumb">
            <a href="#dashboard" class="ac-tab-trigger" data-tab="dashboard">Dashboard</a>
            <span class="material-symbols-outlined">chevron_right</span>
            <span>Payment Methods</span>
          </nav>
          <h2 class="ac-page-title">Payment Methods</h2>
        </div>
        <div class="ac-card" style="padding:2rem; text-align:center;">
          <span class="material-symbols-outlined" style="font-size:2.5rem; opacity:0.3;">credit_card</span>
          <p style="margin-top:0.75rem; color:var(--color-text-secondary);">
            Payment method management is handled by Shopify at checkout.
          </p>
        </div>

      </div><!-- /tab-payment -->

    </div><!-- /ac-content -->
  </div>
</main>

<script>
(function() {

  // ---- Tab System ----
  var panes   = document.querySelectorAll('.ac-tab-pane');
  var navLinks = document.querySelectorAll('.ac-sidenav-link.ac-tab-trigger');

  function showTab(tabId) {
    panes.forEach(function(p) { p.classList.remove('active'); });
    navLinks.forEach(function(l) { l.classList.remove('active'); });

    var pane = document.getElementById('tab-' + tabId);
    if (pane) pane.classList.add('active');

    navLinks.forEach(function(l) {
      if (l.dataset.tab === tabId) l.classList.add('active');
    });
  }

  // All tab triggers (sidebar + inline links)
  document.querySelectorAll('.ac-tab-trigger').forEach(function(el) {
    el.addEventListener('click', function(e) {
      e.preventDefault();
      var tab = this.dataset.tab;
      window.location.hash = tab;
      showTab(tab);
    });
  });

  // Hash on load
  function getHash() {
    var h = window.location.hash.replace('#', '');
    return ['dashboard','orders','addresses','wishlist','payment'].indexOf(h) >= 0 ? h : 'dashboard';
  }
  showTab(getHash());

  window.addEventListener('hashchange', function() { showTab(getHash()); });


  // ---- Order Filter Tabs ----
  document.querySelectorAll('.ac-order-tab').forEach(function(btn) {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.ac-order-tab').forEach(function(b) { b.classList.remove('active'); });
      this.classList.add('active');
      var filter = this.dataset.filter;
      document.querySelectorAll('.ac-order-card').forEach(function(card) {
        card.style.display =
          (filter === 'all' || card.dataset.filter === filter) ? '' : 'none';
      });
    });
  });


  // ---- Wishlist — window.Wishlist (wishlist-js snippet) থেকে data নেয় ----
  var wlGrid   = document.getElementById('wl-grid');
  var wlEmpty  = document.getElementById('wl-empty');
  var wlCount  = document.getElementById('wl-count');
  var wlAddAll = document.getElementById('wl-add-all');

  function fmtMoney(cents) { return '$' + (cents / 100).toFixed(2); }
  function esc(s) { var d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

  function removeItem(id) {
    if (window.Wishlist) window.Wishlist.remove(id);
    renderWL();
  }

  function renderWL() {
    if (!wlGrid) return;
    var items = window.Wishlist ? window.Wishlist.getAll() : [];
    wlGrid.querySelectorAll('.ac-wl-card').forEach(function(c) { c.remove(); });

    if (!items.length) {
      wlEmpty.style.display = 'flex';
      wlCount.textContent   = '0 Items';
      wlAddAll.disabled     = true;
      return;
    }
    wlEmpty.style.display = 'none';
    wlCount.textContent   = items.length + ' Item' + (items.length !== 1 ? 's' : '');
    wlAddAll.disabled     = false;

    items.forEach(function(item) {
      var card = document.createElement('div');
      card.className = 'ac-wl-card';
      var stockBadge = item.available
        ? '<span class="ac-badge shipped">In Stock</span>'
        : '<span class="ac-badge cancelled">Out of Stock</span>';
      var imgHtml = item.image
        ? '<img src="' + esc(item.image) + '" alt="' + esc(item.title) + '" class="ac-wl-img" loading="lazy">'
        : '<div class="ac-wl-no-img"><span class="material-symbols-outlined">image_not_supported</span></div>';

      card.innerHTML =
        '<div class="ac-wl-image-wrap">'
          + '<a href="' + esc(item.url || '#') + '">' + imgHtml + '</a>'
          + '<button class="ac-wl-remove" data-id="' + esc(String(item.id)) + '" aria-label="Remove">'
            + '<span class="material-symbols-outlined">close</span>'
          + '</button>'
        + '</div>'
        + '<div class="ac-wl-body">'
          + '<div class="ac-wl-top">'
            + '<h3 class="ac-wl-title"><a href="' + esc(item.url || '#') + '">' + esc(item.title) + '</a></h3>'
            + stockBadge
          + '</div>'
          + '<p class="ac-wl-price">' + fmtMoney(item.price || 0) + '</p>'
          + '<button class="ac-btn secondary ac-wl-atc" data-id="' + esc(String(item.id)) + '"'
            + (!item.available ? ' disabled' : '') + '>'
            + (item.available ? 'Add to Cart' : 'Out of Stock')
          + '</button>'
        + '</div>';

      wlGrid.insertBefore(card, wlEmpty);
    });

    wlGrid.querySelectorAll('.ac-wl-remove').forEach(function(btn) {
      btn.addEventListener('click', function() { removeItem(this.dataset.id); });
    });
    wlGrid.querySelectorAll('.ac-wl-atc').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var self = this, vid = this.dataset.id;
        self.disabled = true; self.textContent = 'Adding...';
        fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: vid, quantity: 1 }) })
          .then(function(r) { return r.json(); })
          .then(function() {
            if (window.CartDrawer) { window.CartDrawer.refresh(); window.CartDrawer.open(); }
            self.textContent = 'Added!';
            setTimeout(function() { self.disabled = false; self.textContent = 'Add to Cart'; }, 1800);
          })
          .catch(function() { self.disabled = false; self.textContent = 'Add to Cart'; });
      });
    });
  }

  if (wlAddAll) {
    wlAddAll.addEventListener('click', function() {
      var items = window.Wishlist ? window.Wishlist.getAll().filter(function(i) { return i.available; }) : [];
      if (!items.length) return;
      wlAddAll.disabled  = true;
      wlAddAll.innerHTML = '<span class="material-symbols-outlined">hourglass_top</span> Adding...';
      Promise.all(items.map(function(item) {
        return fetch('/cart/add.js', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: item.id, quantity: 1 }) });
      })).then(function() {
        if (window.CartDrawer) { window.CartDrawer.refresh(); window.CartDrawer.open(); }
        wlAddAll.innerHTML = '<span class="material-symbols-outlined">check</span> All Added!';
        setTimeout(function() {
          wlAddAll.disabled  = false;
          wlAddAll.innerHTML = '<span class="material-symbols-outlined">shopping_cart_checkout</span> Add All to Cart';
        }, 2000);
      });
    });
  }

  // wishlist:updated event এ grid re-render
  document.addEventListener('wishlist:updated', renderWL);
  renderWL();

})();
</script>

{% schema %}
{
  "name": "Account",
  "settings": [],
  "presets": [{ "name": "Account" }]
}
{% endschema %}
