<section class="promo-banner-section">
  <div class="container">
    <div class="promo-banner" style="background-image: url('{{ section.settings.background_image | img_url: 'master' }}')">
      <div class="promo-overlay"></div>
      <div class="promo-content">
        <span class="promo-eyebrow">{{ section.settings.eyebrow_text }}</span>
        <h2 class="promo-heading">{{ section.settings.heading }}</h2>
        <p class="promo-subtext">{{ section.settings.subtext }}</p>
        <a href="{{ section.settings.button_url }}" class="btn btn-white">
          {{ section.settings.button_label }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Promo Banner",
  "tag": "section",
  "class": "promo-banner-section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow Text",
      "default": "Limited Time Offer"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main Heading",
      "default": "Up to 50% OFF"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Get the best deals on our premium collection."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Text",
      "default": "Shop The Sale"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner"
    }
  ]
}
{% endschema %}
