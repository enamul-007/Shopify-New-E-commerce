<section class="products-section">
  <div class="container">
    <div class="section-header centered">
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p class="section-subtitle">{{ section.settings.subheading }}</p>
    </div>

    <div class="products-grid">
      {% assign collection = collections[section.settings.collection] %}
      {% assign products_to_show = section.settings.products_to_show | default: 8 %}

      {% for product in collection.products limit: products_to_show %}
        <div class="product-card">
          <div class="product-card-image-wrap">
            <a href="{{ product.url }}">
              <img
                src="{{ product.featured_image | img_url: '500x' }}"
                alt="{{ product.featured_image.alt | escape }}"
                class="product-card-image"
                loading="lazy"
              >
            </a>
            <button class="add-to-cart-btn"
              data-product-id="{{ product.id }}"
              data-variant-id="{{ product.first_available_variant.id }}"
              aria-label="Add to cart">
              <span class="material-symbols-outlined">add_shopping_cart</span>
            </button>
            {% if product.compare_at_price > product.price %}
              {% assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
              <span class="product-badge sale">-{{ discount }}%</span>
            {% elsif product.tags contains 'new' %}
              <span class="product-badge new">New</span>
            {% endif %}
          </div>
          <div class="product-card-info">
            <h3 class="product-name">
              <a href="{{ product.url }}">{{ product.title }}</a>
            </h3>
            <div class="product-pricing">
              <span class="product-price">{{ product.price | money }}</span>
              {% if product.compare_at_price > product.price %}
                <span class="product-compare-price">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>
          </div>
        </div>
      {% else %}
        <p class="no-products">No products found in this collection.</p>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.add-to-cart-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var variantId = this.dataset.variantId;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      }).then(function(res) {
        return res.json();
      }).then(function() {
        document.dispatchEvent(new CustomEvent('cart:updated'));
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Grid",
  "tag": "section",
  "class": "products-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Best Selling Products"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Our most popular items loved by customers worldwide."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to Display"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 16,
      "step": 2,
      "label": "Products to Show",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Product Grid"
    }
  ]
}
{% endschema %}
