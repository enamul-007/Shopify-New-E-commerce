<section class="category-section">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      {% if section.settings.view_all_url != blank %}
        <a href="{{ section.settings.view_all_url }}" class="view-all-link">View All</a>
      {% endif %}
    </div>
    <div class="category-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="category-card" {{ block.shopify_attributes }}>
          <div class="category-card-image" style="background-image: url('{{ block.settings.image | img_url: 'master' }}')"></div>
          <div class="category-card-overlay"></div>
          <div class="category-card-label">
            <p>{{ block.settings.label }}</p>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Grid",
  "tag": "section",
  "class": "category-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Shop by Category"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": "View All URL"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category Label",
          "default": "Men"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "blocks": [
        { "type": "category", "settings": { "label": "Men" } },
        { "type": "category", "settings": { "label": "Women" } },
        { "type": "category", "settings": { "label": "Kids" } },
        { "type": "category", "settings": { "label": "Shoes" } },
        { "type": "category", "settings": { "label": "Bags" } },
        { "type": "category", "settings": { "label": "Accessories" } }
      ]
    }
  ]
}
{% endschema %}
