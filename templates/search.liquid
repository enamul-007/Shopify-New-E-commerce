{% paginate search.results by 10 %}

{{ 'index.css' | asset_url | stylesheet_tag }}

<div class="search-page">
  <div class="search-page-container">

    <!-- Hero Search Header -->
    <div class="search-hero">
      <div class="search-hero-bg"></div>
      <div class="search-hero-content">
        {% if search.performed and search.results_count > 0 %}
          <p class="search-hero-eyebrow">Search Results</p>
          <h1 class="search-hero-heading">
            <span class="search-hero-count">{{ search.results_count }}</span>
            result{% if search.results_count != 1 %}s{% endif %} for
            <em>&ldquo;{{ search.terms | escape }}&rdquo;</em>
          </h1>
        {% elsif search.performed and search.results_count == 0 %}
          <p class="search-hero-eyebrow">No Results</p>
          <h1 class="search-hero-heading">
            Nothing found for <em>&ldquo;{{ search.terms | escape }}&rdquo;</em>
          </h1>
        {% else %}
          <p class="search-hero-eyebrow">Discover</p>
          <h1 class="search-hero-heading">What are you looking for?</h1>
        {% endif %}

        <!-- Search Form -->
        <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
          <div class="search-form-inner">
            <span class="material-symbols-outlined search-form-icon">search</span>
            <input
              type="search"
              name="q"
              id="Search"
              value="{{ search.terms | escape }}"
              placeholder="Search products, articles..."
              class="search-input"
              autocomplete="off"
              aria-label="Search"
            >
            <input type="hidden" name="type" value="product,article,page">
            {% if search.terms != blank %}
              <a href="{{ routes.search_url }}" class="search-clear-btn" aria-label="Clear search">
                <span class="material-symbols-outlined">close</span>
              </a>
            {% endif %}
            <button type="submit" class="search-submit-btn" aria-label="Submit search">
              Search
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Results Area -->
    {% if search.performed %}
      {% if search.results_count == 0 %}

        <!-- Empty State -->
        <div class="search-empty">
          <div class="search-empty-icon">
            <span class="material-symbols-outlined">manage_search</span>
          </div>
          <h2 class="search-empty-title">No results found</h2>
          <p class="search-empty-hint">Try checking your spelling or using more general terms.</p>
          <a href="{{ routes.collections_url }}" class="search-browse-btn">
            <span class="material-symbols-outlined">grid_view</span>
            Browse All Products
          </a>
        </div>

      {% else %}

        <!-- Filter Bar -->
        <div class="search-filter-bar">
          <span class="search-filter-label">Showing {{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %}</span>
        </div>

        <!-- Results Grid -->
        <ul class="search-results-grid">
          {% for item in search.results %}
            <li class="search-result-card" style="--i: {{ forloop.index }}">

              <!-- Image -->
              <a href="{{ item.url }}" class="search-result-img-link">
                {% if item.featured_image != blank %}
                  <img
                    src="{{ item.featured_image | img_url: '400x400', crop: 'center' }}"
                    alt="{{ item.featured_image.alt | default: item.title | escape }}"
                    class="search-result-img"
                    loading="lazy"
                    width="400"
                    height="400"
                  >
                {% else %}
                  <div class="search-result-no-img">
                    <span class="material-symbols-outlined">image_not_supported</span>
                  </div>
                {% endif %}

                <!-- Type Badge -->
                <span class="search-result-type-badge">{{ item.object_type | capitalize }}</span>

                {% if item.object_type == 'product' %}
                  {% if item.compare_at_price > item.price %}
                    <span class="search-result-sale-badge">Sale</span>
                  {% endif %}
                  {% unless item.available %}
                    <span class="search-result-soldout-badge">Sold Out</span>
                  {% endunless %}
                {% endif %}
              </a>

              <!-- Info -->
              <div class="search-result-body">
                <h3 class="search-result-title">
                  <a href="{{ item.url }}">{{ item.title }}</a>
                </h3>

                {% if item.object_type == 'product' %}
                  <div class="search-result-pricing">
                    {% if item.compare_at_price > item.price %}
                      <span class="search-result-price sale">{{ item.price | money }}</span>
                      <s class="search-result-compare">{{ item.compare_at_price | money }}</s>
                    {% else %}
                      <span class="search-result-price">
                        {% if item.price_varies %}From {% endif %}
                        {{ item.price | money }}
                      </span>
                    {% endif %}
                  </div>

                  {% if item.available %}
                    <button
                      class="search-add-cart-btn"
                      data-variant-id="{{ item.first_available_variant.id }}"
                      aria-label="Add {{ item.title }} to cart"
                    >
                      <span class="material-symbols-outlined">add_shopping_cart</span>
                      Add to Cart
                    </button>
                  {% else %}
                    <button class="search-add-cart-btn disabled" disabled>
                      Sold Out
                    </button>
                  {% endif %}

                {% else %}
                  <p class="search-result-excerpt">
                    {{ item.content | strip_html | truncatewords: 20 }}
                  </p>
                  <a href="{{ item.url }}" class="search-read-more">
                    Read more
                    <span class="material-symbols-outlined">arrow_forward</span>
                  </a>
                {% endif %}
              </div>

            </li>
          {% endfor %}
        </ul>

        <!-- Pagination -->
        {% if paginate.pages > 1 %}
          <nav class="search-pagination" aria-label="Search pagination">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" class="page-btn prev">
                <span class="material-symbols-outlined">arrow_back</span>
                Previous
              </a>
            {% else %}
              <span class="page-btn disabled">
                <span class="material-symbols-outlined">arrow_back</span>
                Previous
              </span>
            {% endif %}

            <div class="page-numbers">
              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}" class="page-num {% if part.title == paginate.current_page %}active{% endif %}">
                    {{ part.title }}
                  </a>
                {% else %}
                  {% if part.title == paginate.current_page %}
                    <span class="page-num active">{{ part.title }}</span>
                  {% else %}
                    <span class="page-num ellipsis">&hellip;</span>
                  {% endif %}
                {% endif %}
              {% endfor %}
            </div>

            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" class="page-btn next">
                Next
                <span class="material-symbols-outlined">arrow_forward</span>
              </a>
            {% else %}
              <span class="page-btn disabled">
                Next
                <span class="material-symbols-outlined">arrow_forward</span>
              </span>
            {% endif %}
          </nav>
        {% endif %}

      {% endif %}
    {% endif %}

  </div>
</div>

<script>
  document.querySelectorAll('.search-add-cart-btn:not(.disabled)').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var variantId = this.dataset.variantId;
      if (!variantId) return;

      var self = this;
      var originalHTML = this.innerHTML;
      this.innerHTML = '<span class="material-symbols-outlined spin">progress_activity</span> Adding...';
      this.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 })
      })
      .then(function(res) { return res.json(); })
      .then(function() {
        document.dispatchEvent(new CustomEvent('cart:updated'));
        self.innerHTML = '<span class="material-symbols-outlined">check_circle</span> Added!';
        self.classList.add('added');
        setTimeout(function() {
          self.innerHTML = originalHTML;
          self.disabled = false;
          self.classList.remove('added');
        }, 2000);
      })
      .catch(function() {
        self.innerHTML = originalHTML;
        self.disabled = false;
      });
    });
  });
</script>

{% endpaginate %}
